# API Credentials for LLM Pipeline
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
CEREBRAS_API_KEY=your_cerebras_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Jules Autonomous Agent API Integration
JULES_API_KEY=your_jules_api_key_here
JULES_PROJECT_ID=your_jules_project_id_or_repo_url

# Database Settings
DATABASE_URL=sqlite:///./exam_architect.db

# Server Settings
PORT=8000

# --- Rate Limiting ---
# Auth endpoints (/login, /register): requests per window
RATE_LIMIT_AUTH_REQUESTS=5
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
# Exam generation / study-plan (guest users)
RATE_LIMIT_EXAM_GUEST_REQUESTS=10
RATE_LIMIT_EXAM_GUEST_WINDOW_SECONDS=3600
# Exam generation / study-plan (logged-in users)
RATE_LIMIT_EXAM_USER_REQUESTS=50
RATE_LIMIT_EXAM_USER_WINDOW_SECONDS=3600
# Admin endpoints: requests per window per IP
RATE_LIMIT_ADMIN_REQUESTS=30
RATE_LIMIT_ADMIN_WINDOW_SECONDS=60